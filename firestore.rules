rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /subscribers/{subscriberId} {
      // Keep subscriber list private.
      allow read: if false;

      // Public create-only endpoint for website subscribe form.
      allow create: if
        request.resource.data.keys().hasOnly(["email", "createdAt", "source", "status"]) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 3 &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.source == "website" &&
        request.resource.data.status == "active";

      // Prevent overwrite / edits / deletes from client.
      allow update, delete: if false;
    }

    match /whatsapp_waitlist/{leadId} {
      allow read: if false;

      allow create: if
        request.resource.data.keys().hasOnly(["phone", "createdAt", "source", "status"]) &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 8 &&
        request.resource.data.phone.size() <= 20 &&
        request.resource.data.source == "website" &&
        request.resource.data.status == "active";

      allow update, delete: if false;
    }
  }
}
